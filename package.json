{
  "name": "amble-singapore",
  "version": "1.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:poi-tileset": "node scripts/build-combined-poi-tileset.mjs",
    "predev": "npm run build:poi-tileset",
    "prebuild": "npm run build:poi-tileset",
    "venue-index:build": "node scripts/build-local-venue-index.mjs",
    "venue-index:search": "node scripts/search-local-venues.mjs",
    "venue-index:resolve": "node scripts/resolve-venues-locally.mjs",
    "venue-index:enrich": "node scripts/enrich-event-locations.mjs",
    "dev": "node --env-file-if-exists=.env.local node_modules/vite/bin/vite.js",
    "build": "vite build",
    "benchmark:frontend": "node scripts/benchmark-frontend-performance.mjs",
    "benchmark:release": "node scripts/benchmark-frontend-performance.mjs --runs 1 --settle-ms 1000 --motion-ms 500",
    "restaurant-pipeline": "node --env-file-if-exists=.env.local scripts/restaurant-pipeline.mjs",
    "weekly:refresh": "node --env-file-if-exists=.env.local scripts/run-weekly-refresh.mjs",
    "telegram:webhook": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.telegram.local scripts/configure-telegram-webhook.mjs",
    "plans:migrate": "node scripts/migrate-plan-game.cjs",
    "test:plans": "node --test tests/plan-game.test.mjs && playwright test -c playwright.config.mjs tests/plan-builder.spec.mjs && npm run build && node scripts/smoke-plan-production.mjs",
    "test:restaurants": "node --test tests/restaurant-pipeline.test.mjs && playwright test -c playwright.config.mjs tests/restaurant-ui.spec.mjs",
    "event-pipeline": "node scripts/event-pipeline.mjs",
    "event-pipeline:clear": "node scripts/clear-event-pipeline-data.mjs",
    "web-evidence": "node scripts/extract-web-evidence.mjs",
    "onemap-geocode": "node scripts/query-onemap-location.mjs",
    "test:event-pipeline": "node --test tests/event-pipeline.test.mjs",
    "test:event-sources": "node scripts/verify-event-source-adapters.mjs",
    "test:event-ui": "playwright test -c playwright.config.mjs",
    "test:poi-separation": "node scripts/verify-poi-background-separation.mjs",
    "verify:artifacts": "node scripts/verify-artifact-policy.mjs",
    "smoke:baseline": "node scripts/smoke-production-baseline.mjs",
    "verify": "node scripts/verify-production-baseline.mjs",
    "restore:poi-backgrounds": "node scripts/restore-poi-backgrounds.mjs",
    "postbuild": "node scripts/postbuild-copy-tiles.mjs",
    "serve": "node --env-file-if-exists=.env.local --env-file-if-exists=.env.telegram.local scripts/serve-app.cjs",
    "cloudflare:deploy": "wrangler deploy --config wrangler.vpc.jsonc",
    "cloudflare:dev": "wrangler dev --config wrangler.vpc.jsonc --remote",
    "cloudflare:test": "node --test tests/cloudflare-vpc-proxy.test.mjs",
    "cloudflare:prepare": "npm run build:poi-tileset && node scripts/generate-cloudflare-snapshot.mjs && node scripts/prepare-cloudflare-public.mjs && vite build --config vite.cloudflare.config.cjs",
    "cloudflare:seed:restaurants": "node scripts/generate-cloudflare-restaurant-seed.mjs",
    "cloudflare:cloud:verify-build": "node scripts/verify-cloudflare-frontend.mjs",
    "cloudflare:cloud:deploy": "npm run cloudflare:prepare && npm run cloudflare:cloud:verify-build && wrangler deploy --config wrangler.cloud.jsonc",
    "cloudflare:cloud:dev": "npm run cloudflare:prepare && wrangler dev --config wrangler.cloud.jsonc --remote",
    "cloudflare:cloud:test": "node scripts/generate-cloudflare-snapshot.mjs && node --test tests/cloudflare-cloud-native.test.mjs tests/cloudflare-vpc-proxy.test.mjs tests/device-support.test.mjs tests/cloudflare-frontend-build.test.mjs",
    "cloudflare:r2:verify": "node scripts/verify-r2-tile-delivery.mjs",
    "inspect-glb": "node scripts/inspect-glb.mjs",
    "extract-poi-tileset": "node scripts/extract-poi-tileset.mjs",
    "extract-cbd-poi-tilesets": "node scripts/extract-cbd-poi-tilesets.mjs",
    "update-venue-registry": "node scripts/update-venue-registry.mjs",
    "process-event-pill-eligibility": "node scripts/process-event-pill-eligibility.mjs",
    "create-esplanade-concert-model": "node scripts/create-esplanade-concert-model.mjs",
    "create-esplanade-concert-blender": "/Applications/Blender.app/Contents/MacOS/Blender --background --python scripts/create-esplanade-concert-blender.py",
    "fetch-overlays": "node scripts/fetch-overlays.mjs",
    "fetch-tiles": "node scripts/fetch-tiles.mjs",
    "optimize-tiles": "node scripts/optimize-tiles.mjs",
    "prune-tileset": "node scripts/prune-tileset.mjs",
    "parse-catch-week-md": "node scripts/parse-catch-week-md.mjs"
  },
  "private": true,
  "license": "UNLICENSED",
  "devDependencies": {
    "3d-tiles-tools": "^0.5.3",
    "cesium": "^1.86.1",
    "playwright": "^1.61.1",
    "vite": "^8.1.5",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@deck.gl/core": "~8.5.10",
    "@deck.gl/extensions": "~8.5.10",
    "@deck.gl/geo-layers": "~8.5.10",
    "@deck.gl/layers": "~8.5.10",
    "@deck.gl/mapbox": "~8.5.10",
    "@deck.gl/mesh-layers": "~8.5.10",
    "@loaders.gl/3d-tiles": "~3.0.12",
    "@luma.gl/shadertools": "~8.5.10",
    "@phosphor-icons/web": "^2.1.2",
    "maplibre-gl": "~1.15.3",
    "osm-pbf-parser": "^2.3.0",
    "three": "^0.161.0"
  },
  "optionalDependencies": {
    "3d-tiles-tools": "https://gitpkg.now.sh/CesiumGS/3d-tiles-validator/tools?main",
    "fs-extra": "~10.0.0",
    "gltf-pipeline": "~3.0.4",
    "node-fetch": "^3.3.2"
  },
  "type": "module"
}
