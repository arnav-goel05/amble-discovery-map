{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amble.local/contracts/voice-action.schema.json",
  "title": "Voice Action Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actionId",
    "version",
    "description",
    "argumentSchema",
    "eligibleStates",
    "confirmationClass",
    "contextProvider",
    "resultSchema"
  ],
  "properties": {
    "actionId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)+$"
    },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "description": { "type": "string", "minLength": 1, "maxLength": 160 },
    "argumentSchema": {
      "type": "object",
      "required": ["type", "additionalProperties", "properties"],
      "properties": {
        "type": { "const": "object" },
        "additionalProperties": { "const": false },
        "properties": { "type": "object" },
        "required": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "eligibleStates": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "confirmationClass": { "enum": ["reversible", "consequential"] },
    "contextProvider": { "type": "string", "minLength": 1 },
    "resultSchema": { "type": "object" },
    "undoActionId": {
      "type": ["string", "null"],
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z][a-z0-9]*)+$"
    }
  }
}
