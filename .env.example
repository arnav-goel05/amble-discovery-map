# Public server
HOST=127.0.0.1
PORT=4173
PUBLIC_BASE_URL=https://example.invalid
PLAN_STORE_ROOT=/var/lib/whats-here/plans
# Optional local-development fallback for R2-hosted 3D geometry.
TILE_FALLBACK_ORIGIN=https://amble.amble-sg.workers.dev

# Sole private administrator (server-side only)
ADMIN_PASSWORD_HASH=

# Optional Telegram challenge (server-side only)
TELEGRAM_GAMES_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
ADAPTIVE_LOCATION_VERIFICATION_ENABLED=true
PHOTO_VERIFICATION_ENABLED=true

# Optional providers are usable only when data/provider-policy.json classifies them free/open.
